API_URL=http://localhost:9443
DEBUGGER_OFF=true
DEVELOPMENT=true
PORT=8443
#SERVER - 'PINGAM' or 'PINGONE'
SERVER=

# SDK configuration (clientId, discoveryEndpoint, scopes, redirectUri) is no
# longer sourced from environment variables. Copy config.example.json to
# config.json and fill in your values.

# REST_OAUTH_CLIENT and REST_OAUTH_SECRET are used by the todo-api test server
# during e2e runs — inject them via CI secrets, not this file.
