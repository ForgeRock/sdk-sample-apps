<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/ping_red_light"
                android:endColor="@color/ping_red_dark"
                android:angle="90" />
        </shape>
    </item>
    
    <!-- Logo centered -->
    <item>
        <bitmap
            android:src="@drawable/ping_logo"
            android:gravity="center" />
    </item>
</layer-list>
