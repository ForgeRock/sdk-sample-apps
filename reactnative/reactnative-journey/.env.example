# TODO: Copy this file to `.env` and replace the placeholder values below with your actual configuration:
# - JOURNEY_SERVER_URL: Your PingAM/AIC server URL
# - JOURNEY_REALM: Your authentication realm
# - JOURNEY_COOKIE: Your session cookie name
# - JOURNEY_CLIENT_ID: Your OAuth 2.0 client ID
# - JOURNEY_DISCOVERY_ENDPOINT: Your OIDC discovery endpoint URL
# - JOURNEY_REDIRECT_URI: Your app's redirect URI
# - JOURNEY_SCOPES: Your OAuth 2.0 scopes
# - FACEBOOK_*: Your Facebook app credentials (only needed for external IdP login)
# - GOOGLE_IOS_*: Your Google iOS client credentials (only needed for external IdP login)

# Journey config
JOURNEY_SERVER_URL=https://your-journey-host.example.com/am
JOURNEY_REALM=your-journey-realm
JOURNEY_COOKIE=your-journey-cookie-name
JOURNEY_CLIENT_ID=your-journey-client-id
JOURNEY_DISCOVERY_ENDPOINT=https://your-journey-host.example.com/am/oauth2/your-journey-realm/.well-known/openid-configuration
JOURNEY_REDIRECT_URI=org.forgerock.demo://oauth2redirect
JOURNEY_SCOPES=openid,email,profile,address
JOURNEY_SHOW_DEBUG_PANEL=false

# Facebook App config (external IdP login)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_LOGIN_PROTOCOL_SCHEME=fbyour-facebook-app-id
FACEBOOK_CLIENT_TOKEN=your-facebook-client-token

# Google client app iOS config (external IdP login)
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
GOOGLE_IOS_REVERSED_CLIENT_ID=com.googleusercontent.apps.your-google-ios-client-id
