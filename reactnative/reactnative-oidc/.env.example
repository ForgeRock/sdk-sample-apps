# TODO: Copy this file to `.env` and replace the placeholder values below with your actual configuration:
# - AIC_CLIENT_ID: Your PingAM/AIC OAuth 2.0 client ID
# - AIC_DISCOVERY_ENDPOINT: Your PingAM/AIC OIDC discovery endpoint URL
# - AIC_REDIRECT_URI: Your app's redirect URI for the AIC flow
# - AIC_SCOPES: Your OAuth 2.0 scopes for the AIC flow
# - PINGONE_CLIENT_ID: Your PingOne OAuth 2.0 client ID
# - PINGONE_DISCOVERY_ENDPOINT: Your PingOne OIDC discovery endpoint URL
# - PINGONE_REDIRECT_URI: Your app's redirect URI for the PingOne flow
# - PINGONE_SCOPES: Your OAuth 2.0 scopes for the PingOne flow
# - PINGONE_ACR_VALUES: Your PingOne flow ACR value, if required

# PingA Advanced Identity Cloud / PingAM OIDC config
AIC_CLIENT_ID=your-aic-client-id
AIC_DISCOVERY_ENDPOINT=https://your-aic-host.example.com/am/oauth2/your-aic-realm/.well-known/openid-configuration
AIC_REDIRECT_URI=org.forgerock.oidc://oauth2redirect
AIC_SCOPES=openid,profile,email,address,phone

# PingOne OIDC config
PINGONE_CLIENT_ID=your-pingone-client-id
PINGONE_DISCOVERY_ENDPOINT=https://auth.pingone.ca/your-environment-id/as/.well-known/openid-configuration
PINGONE_REDIRECT_URI=org.forgerock.oidc://oauth2redirect
PINGONE_SCOPES=openid,email,address
PINGONE_ACR_VALUES=your-flow-acr-id
PINGONE_ENVIRONMENT_LABEL=PingOne Flow
