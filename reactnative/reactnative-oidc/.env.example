# PingAdvancedIdentityCloud / PingAM OIDC config
AIC_CLIENT_ID=your-aic-client-id
AIC_DISCOVERY_ENDPOINT=https://your-aic-host.example.com/am/oauth2/your-aic-realm/.well-known/openid-configuration
AIC_REDIRECT_URI=org.forgerock.oidc://oauth2redirect
AIC_SCOPES=openid,profile,email,address,phone

# PingOne OIDC config
PINGONE_CLIENT_ID=your-pingone-client-id
PINGONE_DISCOVERY_ENDPOINT=https://auth.pingone.ca/your-environment-id/as/.well-known/openid-configuration
PINGONE_REDIRECT_URI=org.forgerock.oidc://oauth2redirect
PINGONE_SCOPES=openid,email,address
PINGONE_ACR_VALUES=your-flow-acr-id
PINGONE_ENVIRONMENT_LABEL=PingOne Flow
